# =============================================================================
# ePorezna / PKK — konfiguracija za Node CLI (NIJE potrebno za browser alat)
# =============================================================================
# Kopiraj u `.env` i popuni iz SVJEŽEG zahtjeva u browseru.
#
# Kako dobiti vrijednosti:
#   1. Otvori https://upo.porezna-uprava.hr/profil/uvid-u-pkk i prijavi se (NIAS).
#   2. DevTools -> Network -> klikni na zahtjev `pkk-dohvati-stanje`.
#   3. Desni klik -> Copy -> "Copy as cURL".
#   4. Iz njega prepiši:
#        cookie token-handler.session=...   ->  PKK_SESSION
#        header x-redirect-state: ...        ->  PKK_REDIRECT_STATE
#
# VAŽNO: oboje istječe brzo. Kod 401/403 osvježi obje vrijednosti.
# NIKAD ne commitaj popunjeni .env (u .gitignore je).
# -----------------------------------------------------------------------------

PKK_SESSION=ovdje_zalijepi_token_handler_session
PKK_REDIRECT_STATE=ovdje_zalijepi_x_redirect_state

# Naziv firme (za zaglavlje reporta)
PKK_FIRMA=Moja firma d.o.o.

# Raspon godina (uključivo). START = godina osnutka. Prazno END = tekuća godina.
PKK_START_YEAR=2016
PKK_END_YEAR=

PKK_DOKUMENT_OZNAKA=UVIDI_PKK_PROFIL
